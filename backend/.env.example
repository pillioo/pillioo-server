# LLM (draft generation, evidence chat). OPENAI_BASE_URL is optional -- leave
# unset to call api.openai.com directly with OPENAI_API_KEY above. Set it to
# route chat/completion calls through an OpenAI-compatible gateway instead
# (embeddings always call the OpenAI API directly regardless of this value).
LLM_MODEL=gpt-5.4-mini
OPENAI_API_KEY=
EMBEDDING_API_KEY=
OPENAI_API_BASE=https://factchat-cloud.mindlogic.ai/v1/gateway/

DB_HOST=postgres
DB_PORT=5432
DB_NAME=pillioo_db
DB_USER=user
DB_PASSWORD=asdf1234
DATABASE_URL=postgresql+psycopg2://user:asdf1234@postgres:5432/pillioo_db

EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
EMBEDDING_BATCH_SIZE=64

MILVUS_COLLECTION=evidence_chunks
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_URI=http://milvus:19530
MILVUS_URL=http://milvus:19530
